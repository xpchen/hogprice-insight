# 数据库配置
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/hogprice?charset=utf8mb4

# JWT密钥（生产环境请修改）
SECRET_KEY=your-secret-key-change-in-production

# Token过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://localhost:5173"]

# 审计对账时设为 true 禁用图表缓存，保证拿到真实数据库结果
# DISABLE_CHART_CACHE=true

# 导入后缓存预热：import_data.py 会携带 X-Quick-Chart-Secret 请求图表 API 刷新缓存
# 不配置时预热请求可能 401；建议设置与下方一致以便 import_data.bat 预热成功
QUICK_CHART_INTERNAL_SECRET=hogprice-internal-secret-2024
# 预计算（含农历）单次请求超时秒数，默认 900；农历计算久时可适当调大
# QUICK_CHART_PRECOMPUTE_TIMEOUT=900
